#!/bin/sh
# GNT Reader pre-commit hook
#
# Two-phase gate (port-soft from Tanakh — detect stale derived layers but
# do NOT auto-modify files):
#
# Phase 1 — Cascade-staleness detection
#   When v4/grk chapter files are staged, verify that the cascade was
#   run: line counts match between staged v4 and the corresponding v4/eng-kjv,
#   and books/<slug>.html is also staged. If stale, block with an instructive
#   message. This hook does NOT auto-modify files (per memory
#   feedback_verify_cascade_output.md — regenerate_english.py's proportional-
#   redistribute heuristic can produce misaligned output that needs hand-
#   correction; auto-staging would bypass the two-check gate).
#
# Phase 2 — eng-kjv coverage gate
#   Runs scan_eng_kjv_coverage.py --baseline-check on commits that touch
#   v4/grk, v4/eng-kjv, or regenerate_english.py. Blocks if any v4/grk
#   line with Greek content has a blank eng-kjv counterpart that wasn't
#   in data/eng-kjv-coverage.baseline.json. Closes the blind spot that
#   the bracket-pericope bug (commit 7f3c361c) exploited.
#
# Phase 3 — Validator regression gate
#   Runs run_all.py --baseline-check on commits that touch the editorial
#   corpus, the syntax-reference table, or validator code (.py/.yaml).
#   Canon-prose-only and other docs-only commits skip — they cannot affect
#   validator candidate counts. Tightened 2026-05-05 (port from Tanakh).
#   Blocks if finding counts increase vs validators/.baseline.json.
#
# Install (one-time):
#   cp validators/hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# Bypass (Stan-only, explicit decision):
#   git commit --no-verify

set -e
REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

# ── Phase 1: cascade-staleness detection ───────────────────────────────────

V4_STAGED=$(git diff --cached --name-only --diff-filter=AM | grep -E "^data/text-files/v4/grk/[^/]+/[^/]+\.txt$" || true)

if [ -n "$V4_STAGED" ]; then
    echo ""
    echo "[pre-commit] v4/grk chapters staged. Checking cascade freshness..."

    BOOKS_AFFECTED=""
    STALE_FOUND=0

    for V4_FILE in $V4_STAGED; do
        # path: data/text-files/v4/grk/<NN-book>/<slug>-<NN>.txt
        REL_PATH=${V4_FILE#data/text-files/v4/grk/}
        BOOK_SUBDIR=${REL_PATH%%/*}
        FILENAME=${REL_PATH##*/}
        SLUG=${FILENAME%%-*}

        # Track unique books (for HTML-build check)
        case " $BOOKS_AFFECTED " in
            *" $SLUG "*) ;;
            *) BOOKS_AFFECTED="$BOOKS_AFFECTED $SLUG" ;;
        esac

        # Line-count parity: staged v4 vs index v4/eng-kjv
        EN_PATH="data/text-files/v4/eng-kjv/$BOOK_SUBDIR/$FILENAME"

        if ! git cat-file -e ":$EN_PATH" 2>/dev/null; then
            echo "[pre-commit]   STALE: $FILENAME — v4/eng-kjv not tracked ($EN_PATH)"
            STALE_FOUND=1
            continue
        fi

        V4_LINES=$(git show ":$V4_FILE" | grep -cv "^$" || true)
        EN_LINES=$(git show ":$EN_PATH" | grep -cv "^$" || true)

        if [ "$V4_LINES" != "$EN_LINES" ]; then
            echo "[pre-commit]   STALE: $FILENAME — v4=$V4_LINES non-blank lines, v4/eng-kjv=$EN_LINES"
            STALE_FOUND=1
        fi
    done

    # HTML check: each affected book's HTML must be staged
    HTML_STAGED=$(git diff --cached --name-only --diff-filter=AM | grep -E "^books/[^/]+\.html$" || true)

    for BOOK in $BOOKS_AFFECTED; do
        if ! echo "$HTML_STAGED" | grep -qx "books/$BOOK.html"; then
            echo "[pre-commit]   STALE: books/$BOOK.html not staged (book had v4 edits)"
            STALE_FOUND=1
        fi
    done

    if [ "$STALE_FOUND" -ne 0 ]; then
        echo ""
        echo "[pre-commit] BLOCKED: cascade output is stale relative to v4/grk edits."
        echo "[pre-commit] Run the cascade for affected books, then re-stage:"
        for BOOK in $BOOKS_AFFECTED; do
            echo "    PYTHONIOENCODING=utf-8 py -3 scripts/regenerate_english.py --book $BOOK"
            echo "    PYTHONIOENCODING=utf-8 py -3 scripts/build_books.py --book $BOOK"
        done
        echo ""
        echo "[pre-commit] Note: this hook does NOT auto-modify files."
        echo "[pre-commit] After running the cascade, review the output (see memory:"
        echo "[pre-commit] feedback_two_check_cascade.md) before re-staging."
        echo ""
        exit 1
    fi

    echo "[pre-commit] Cascade fresh. Proceeding to Phase 2."
    echo ""
fi

# ── Phase 2: eng-kjv coverage gate ──────────────────────────────────────────
#
# Closes a blind spot in the Phase 1 freshness check + verify_word_order:
# both compare grk-side counts/content, neither flags the case where
# eng-kjv has a blank line where v4/grk has Greek content. Shipped the
# bracket-pericope bug (commit 7f3c361c) — Mark 16:9-20 + John 7:53-8:11
# silently blank for the duration. Ports the validator-regression-gate
# pattern: baseline of known-blank lines, fail on increase.

ENG_KJV_TOUCHED=$(git diff --cached --name-only | grep -E "^(data/text-files/v4/(grk|eng-kjv)/|scripts/regenerate_english\.py$)" || true)

if [ -n "$ENG_KJV_TOUCHED" ]; then
    echo "[pre-commit] v4/grk or eng-kjv files staged. Running scan_eng_kjv_coverage --baseline-check..."
    echo ""

    PYTHONIOENCODING=utf-8 py -3 scripts/scan_eng_kjv_coverage.py --baseline-check
    COV_RESULT=$?

    if [ $COV_RESULT -ne 0 ]; then
        echo ""
        echo "[pre-commit] BLOCKED: new eng-kjv coverage misses vs baseline."
        echo "[pre-commit] Either:"
        echo "  (a) fix the alignment so the listed v4/grk lines produce English, OR"
        echo "  (b) update the baseline if the increase is structural & intentional:"
        echo "      PYTHONIOENCODING=utf-8 py -3 scripts/scan_eng_kjv_coverage.py --update-baseline"
        echo ""
        exit 1
    fi

    echo "[pre-commit] eng-kjv coverage OK. Proceeding to Phase 3."
    echo ""
fi

# ── Phase 3: validator regression gate ──────────────────────────────────────

RELEVANT=$(git diff --cached --name-only | grep -E "^(data/text-files/v4/grk/|data/syntax-reference/|validators/.*\.(py|yaml)$)" || true)

if [ -z "$RELEVANT" ]; then
    echo "[pre-commit] Docs-only commit. Skipping baseline-check."
    exit 0
fi

echo ""
echo "[pre-commit] Canon/corpus/validator files staged. Running run_all --baseline-check..."
echo ""

PYTHONIOENCODING=utf-8 py -3 validators/run_all.py --baseline-check
RESULT=$?

if [ $RESULT -ne 0 ]; then
    echo ""
    echo "[pre-commit] BLOCKED: validators report new candidates vs baseline."
    echo "[pre-commit] Either:"
    echo "  (a) fix the new violations and re-stage, OR"
    echo "  (b) update the baseline if the increase is intentional:"
    echo "      PYTHONIOENCODING=utf-8 py -3 validators/run_all.py --update-baseline"
    echo ""
    exit 1
fi

echo ""
echo "[pre-commit] No regressions vs baseline. Proceeding."
echo ""
exit 0
